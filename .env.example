# Copy file này thành .env rồi điền secret thật.
# GIAO DIỆN TOOL chỉ nhập alias bên trái (ví dụ: pass_mac_dinh, pass_giai_phap, pass_ssh_root, snmpstring_mac_dinh)
# APP sẽ tự lấy secret thật từ biến môi trường cùng tên nhưng viết HOA.

# Alias cho password hiển thị trên giao diện
PASS_MAC_DINH=thay_bang_password_giao_dien_mac_dinh
PASS_GIAI_PHAP=thay_bang_password_giai_phap
PASS_SSH_ROOT=thay_bang_password_ssh_root
PASS_SSH_SERVER_01=thay_bang_password_ssh_server_nhom_1
PASS_SSH_SERVER_02=thay_bang_password_ssh_server_nhom_2
SNMPSTRING_MAC_DINH=thay_bang_snmp_string_thuc_te

# Proxy SSH dùng để chạy snmpget từ xa
PROXY_SNMP_USERNAME=root
PROXY_SNMP_PASSWORD=thay_bang_password_proxy_snmp
PROXY_SNMP_HOST_1=163.223.58.150
PROXY_SNMP_HOST_2=163.223.58.132

# Optional tuning
LOGIN_LOG_LEVEL=INFO
MAX_SSH_SCAN_WORKERS=10
MAX_WEB_SCAN_WORKERS=20
MAX_SOLUTION_SCAN_WORKERS=8
WEBSITE_CONNECT_TIMEOUT=3
WEBSITE_READ_TIMEOUT=5
SOLUTION_HTTP_TIMEOUT=15
LOGIN_TRACE_LIMIT=200
SSH_CONNECT_TIMEOUT=5
SSH_COMMAND_TIMEOUT=10
SNMP_DEFAULT_TIMEOUT=1
SNMP_DEFAULT_RETRIES=0
